{
  "name": "the-fix-collective",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "prisma generate && WATCHPACK_POLLING=true next dev --port 3000",
    "dev:3001": "prisma generate && WATCHPACK_POLLING=true next dev --port 3001",
    "build": "NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "build:vercel": "prisma migrate deploy && NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:set-user-role": "node scripts/set-user-role.mjs",
    "db:push": "prisma db push",
    "calendar:poc": "tsx --env-file=.env.local scripts/calendar-poc.ts",
    "directory:sync": "tsx --env-file=.env.local scripts/sync-usda-directory.ts",
    "directory:benchmark": "tsx --env-file=.env.local scripts/benchmark-directory-state.ts",
    "test:calendar": "tsx --test src/services/calendar/calendar.test.ts",
    "test:unit": "tsx --test src/lib/platformFee.test.ts src/lib/auth.test.ts src/services/calendar/calendar.test.ts",
    "test:booking-slots": "tsx --test src/lib/bookingSlots.test.ts",
    "test": "npm run test:unit"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "@sentry/nextjs": "^10.65.0",
    "@vercel/blob": "^2.3.2",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
    "encoding": "^0.1.13",
    "googleapis": "^173.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.542.0",
    "next": "^16.2.4",
    "next-auth": "^4.24.14",
    "openai": "^4.104.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-leaflet": "^4.2.1",
    "resend": "^4.8.0",
    "sanitize-html": "^2.17.5",
    "stripe": "^22.3.1",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/leaflet": "^1.9.12",
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "@types/sanitize-html": "^2.16.1",
    "autoprefixer": "^10.4.19",
    "eslint": "^9.39.1",
    "eslint-config-next": "16.2.4",
    "postcss": "^8.5.10",
    "prisma": "6.19.3",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.22.4",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "overrides": {
    "minimatch": "^9.0.7",
    "postcss": "^8.5.10",
    "uuid": "^14.0.0"
  }
}
