generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Roles stored as strings; see src/lib/roles.ts

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String?
  name         String?
  /// Profile photo URL (header avatar; synced from vendor profile when set)
  imageUrl     String?
  /// Local neighborhoods the member shops or wants to shop (free text)
  shopNeighborhoods String?
  role         String   @default("CUSTOMER") // ADMIN | VENDOR | CUSTOMER
  /// E.164 when set (e.g. +15551234567); unique when not null
  phone              String?   @unique
  phoneVerifiedAt    DateTime?
  /// NONE | EMAIL | SMS
  twoFactorMethod    String    @default("NONE")
  /// When set, user agreed to receive SMS for security (verification & sign-in codes).
  consentSmsTwoFactorAt DateTime?
  /// When set, user agreed to receive security one-time codes by email for sign-in.
  consentEmailTwoFactorAt DateTime?
  /// Acknowledged SMS/2FA terms at sign-up (before adding a phone).
  smsTwoFactorSignupConsentAt DateTime?
  /// Opt-in for marketing/promotional email and SMS from RootSync.
  marketingOptIn     Boolean   @default(false)
  marketingOptInAt     DateTime?
  /// Stripe Connect v2 account ID (`acct_...`) used for onboarding and direct charges.
  stripeConnectAccountId String? @unique
  /// Last known subscription status from billing webhooks (sample storage for demo).
  stripeSubscriptionStatus String?
  /// Last known subscribed price id from billing webhooks.
  stripeSubscriptionPriceId String?
  /// Last known subscription period end from billing webhooks.
  stripeSubscriptionCurrentPeriodEnd DateTime?
  /// Accepted Terms & Conditions (e.g. at sign-up).
  termsAcceptedAt    DateTime?
  /// Accepted Privacy Policy (e.g. at sign-up).
  privacyAcceptedAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  orders       Order[]
  bookingsAsMember Booking[] @relation("BookingMember")
  vendorProfile VendorProfile?
  communityPosts CommunityPost[]
  rootSyncConversations RootSyncConversation[]
  directThreadsAsLow  DirectThread[] @relation("DirectThreadLow")
  directThreadsAsHigh DirectThread[] @relation("DirectThreadHigh")
  directMessages        DirectMessage[]
  passwordResetTokens PasswordResetToken[]
  loginChallenges     LoginChallenge[]
  pulseEvents           PulseEvent[]
  pulseReactionsGiven   PulseReaction[] @relation("PulseReactionGiver")
  pulseScore            PulseScore?
  vendorPulseReviews    VendorPulseReview[] @relation("VendorPulseReviewAuthor")
  growthContactsAsMember GrowthContact[] @relation("GrowthContactMember")
  growthCrmNotesAuthored GrowthCrmNote[] @relation("GrowthCrmNoteAuthor")
  growthMarketingEvents  GrowthMarketingEvent[] @relation("GrowthMarketingEventUser")
}

/// One-time password reset link tokens (hashed at rest).
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([tokenHash])
  @@index([userId])
}

/// OTP challenges for login 2FA and phone verification.
model LoginChallenge {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// LOGIN | PHONE_VERIFY
  purpose    String
  /// EMAIL | SMS
  channel    String
  codeHash   String
  /// E.164 for PHONE_VERIFY (code is sent to this number)
  targetPhone String?
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Direct messages between two users. participantLowId is always lexicographically before participantHighId.
model DirectThread {
  id                 String    @id @default(cuid())
  participantLowId   String
  participantLow     User      @relation("DirectThreadLow", fields: [participantLowId], references: [id], onDelete: Cascade)
  participantHighId  String
  participantHigh    User      @relation("DirectThreadHigh", fields: [participantHighId], references: [id], onDelete: Cascade)
  lastMessageAt      DateTime?
  participantLowLastReadAt  DateTime?
  participantHighLastReadAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  messages           DirectMessage[]

  @@unique([participantLowId, participantHighId])
  @@index([participantLowId])
  @@index([participantHighId])
  @@index([lastMessageAt])
}

model DirectMessage {
  id        String       @id @default(cuid())
  threadId  String
  thread    DirectThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime     @default(now())

  @@index([threadId, createdAt])
}

model RootSyncConversation {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  messages  RootSyncMessage[]

  @@index([userId])
  @@index([userId, updatedAt])
}

model RootSyncMessage {
  id             String   @id @default(cuid())
  conversationId String
  conversation   RootSyncConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String
  content        String
  createdAt      DateTime @default(now())

  @@index([conversationId])
}

model VendorProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  displayName     String
  /// Public profile photo on marketplace vendor pages and account avatar
  profileImageUrl String?
  bio             String?
  contactEmail    String?
  pickupLocation  String?
  /// Public website (https), shown on marketplace
  website         String?
  /// Default external checkout URL (Stripe Payment Link, PayPal, etc.) for listings
  paymentLinkUrl  String?
  /// WGS84 — set in vendor profile for map pin (optional)
  latitude        Float?
  longitude       Float?
  /// Platform shop this vendor manages (urban-roots | self-care | stitch | survival-kits)
  shopSlug        String?  @unique
  /// Public Discover URL segment: /discover/vendors/{publicSlug}
  publicSlug      String?  @unique
  /// Image/video carousel on the public vendor profile
  mediaCarouselJson Json?
  status          String   @default("PENDING") // PENDING | APPROVED | REJECTED | SUSPENDED
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  offerings       Offering[]
  listings        Listing[]
  bookings        Booking[]
  claimedDirectoryListing DirectoryListing?
  growthContacts  GrowthContact[]
  growthTags      GrowthTag[]
  growthFunnels     GrowthFunnel[]
  growthLandingPages GrowthLandingPage[]
  growthQrCampaigns GrowthQrCampaign[]
  growthEmailCampaigns GrowthEmailCampaign[]
  growthEmailSequences GrowthEmailSequence[]
  growthSegments    GrowthSegment[]
  growthTasks       GrowthTask[]
  growthConsultationLeads GrowthConsultationLead[]
  growthMarketingEvents GrowthMarketingEvent[]
  vendorPulseReviews    VendorPulseReview[]
}

/// View-only imported business — not a Vendor; see docs/adr/ADR-006-directory-listings.md
model DirectoryListing {
  id            String   @id @default(cuid())
  name          String
  description   String?
  /// FARMERS_MARKET | CSA | ON_FARM_MARKET | FOOD_HUB | AGRITOURISM
  directoryType String
  category      String?

  addressLine1  String?
  addressLine2  String?
  city          String?
  state         String?
  zip           String?
  latitude      Float?
  longitude     Float?

  phone   String?
  email   String?
  website String?

  source        String   @default("USDA")
  externalId    String
  externalUrl   String?
  rawSourceJson Json?
  lastSyncedAt  DateTime?

  /// UNCLAIMED | PENDING | CLAIMED
  claimStatus   String   @default("UNCLAIMED")
  claimedVendorProfileId String? @unique
  claimedVendorProfile   VendorProfile? @relation(fields: [claimedVendorProfileId], references: [id], onDelete: SetNull)

  /// ACTIVE | HIDDEN
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, externalId])
  @@index([directoryType])
  @@index([state, city])
  @@index([status])
  @@index([latitude, longitude])
}

/// Internal vendor-managed object; see docs/adr/ADR-001-offering-listing-model.md
model Offering {
  id                 String    @id @default(cuid())
  vendorProfileId    String
  vendorProfile      VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  /// PRODUCT | SERVICE | RESOURCE | EVENT — see src/lib/roles.ts LISTING_TYPE
  listingType        String    @default("PRODUCT")
  /// DRAFT | SCHEDULED | ACTIVE | PAUSED | ARCHIVED — see OFFERING_STATUS
  status             String    @default("DRAFT")
  title              String
  description        String
  priceCents         Int       @default(0)
  category           String?
  imageUrl           String?
  /// Optional checkout link (e.g. Stripe Payment Link) — vendor-provided
  paymentUrl         String?
  /// Optional catalog page when no payment link (or in addition)
  productUrl         String?
  /// Stripe Product id on the vendor's connected account (`prod_…`)
  stripeProductId    String?
  /// Stripe Price id for the current default price (`price_…`)
  stripePriceId      String?
  /// Internal vendor notes (not shown on public listing)
  vendorNotes        String?
  scheduledPublishAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  listing            Listing?
  productDetails     ProductDetails?
  serviceDetails     ServiceDetails?
  resourceDetails    ResourceDetails?
  eventDetails       EventDetails?
  availabilityRules  ServiceAvailabilityRule[]
  intakeQuestions    ServiceIntakeQuestion[]
  bookings           Booking[]
  variants           OfferingVariant[]

  @@index([vendorProfileId])
  @@index([status])
  @@index([listingType])
}

/// Public discoverable face of an Offering; Members interact with Listings
model Listing {
  id              String   @id @default(cuid())
  offeringId      String   @unique
  offering        Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  vendorProfileId String
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  listingType     String
  title           String
  description     String
  priceCents      Int      @default(0)
  category        String?
  imageUrl        String?
  /// PUBLIC | HIDDEN — see LISTING_VISIBILITY
  visibility      String   @default("HIDDEN")
  publishedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  orderItems      OrderItem[]
  bookings        Booking[]
  vendorPulseReviews VendorPulseReview[]

  @@index([vendorProfileId])
  @@index([listingType])
  @@index([visibility])
}

model ProductDetails {
  offeringId       String  @id
  offering         Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  requiresShipping Boolean @default(true)
  sku              String?
}

model ServiceDetails {
  offeringId          String  @id
  offering            Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  /// CONSULTATION | ONE_TIME | SUBSCRIPTION — see SERVICE_KIND
  serviceKind         String  @default("ONE_TIME")
  durationMinutes     Int?
  serviceRadius       String?
  terms               String?
  bookingUrl          String?
  /// VIRTUAL | IN_PERSON | HYBRID — see FULFILLMENT_METHOD
  fulfillmentMethod   String  @default("VIRTUAL")
  defaultTimeZone     String  @default("America/New_York")
}

model ResourceDetails {
  offeringId      String  @id
  offering        Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  /// EBOOK | BUILD_PLAN | GUIDE | CHECKLIST | TEMPLATE — see RESOURCE_SUBTYPE
  resourceSubtype String?
  format          String?
  fileUrl         String?
}

model EventDetails {
  offeringId String    @id
  offering   Offering  @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  startsAt   DateTime?
  endsAt     DateTime?
  location   String?
  venue      String?
  capacity   Int?
}

model CommunityPost {
  id               String   @id @default(cuid())
  authorId         String
  author           User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content          String
  roleAtPost       String
  showVendorBadge  Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  /// Set when content is edited; used for “Edited” label and sorting with `updatedAt`.
  editedAt         DateTime?
  /// Images, videos, and file attachments (`PulsePostMediaItem[]`).
  mediaJson        Json?
  /// DRAFT posts are visible only to the author until published.
  status           String   @default("PUBLISHED")

  pulseReactions   PulseReaction[]

  @@index([authorId])
  @@index([authorId, status])
  @@index([createdAt])
  @@index([updatedAt])
}

model Order {
  id                  String    @id @default(cuid())
  userId              String?
  email               String
  status              String
  stripeSessionId     String?   @unique
  stripePaymentIntent String?
  stripeRefundId      String?
  refundedAt          DateTime?
  subtotalCents       Int
  shippingCents       Int       @default(0)
  totalCents          Int
  shippingName        String?
  shippingLine1       String?
  shippingLine2       String?
  shippingCity        String?
  shippingState       String?
  shippingPostal      String?
  shippingCountry     String?
  trackingCarrier     String?
  trackingNumber      String?
  shippedAt           DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  items               OrderItem[]
  booking             Booking?
  vendorPulseReview   VendorPulseReview?

  @@index([userId])
  @@index([email])
  @@index([stripeSessionId])
  @@index([createdAt])
}

model OrderItem {
  id                   String   @id @default(cuid())
  orderId              String
  productId            String
  name                 String
  quantity             Int
  priceCents           Int
  type                 String
  format               String?
  downloadKey          String?
  listingId            String?
  listing              Listing? @relation(fields: [listingId], references: [id], onDelete: SetNull)
  variantId            String?
  variant              OfferingVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([listingId])
}

/// Admin-editable storefront shop landing (four platform shops). Null fields fall back to code defaults.
model ShopPage {
  id                  String   @id @default(cuid())
  /// urban-roots | self-care | stitch | survival-kits
  shopSlug            String   @unique
  /// Overrides SHOPS[].name when set
  name                String?
  tagline             String?
  description         String?
  /// Shop landing categories (JSON array of { id, name, description })
  categoriesJson      Json?
  /// Legacy / unused — featured items come from the newest published ShopCatalogListing rows.
  featuredJson        Json?
  /// “Coming soon” cards (JSON array of { title, description, href, cta })
  featureSectionsJson Json?
  /// Image/video carousel between featured items and coming soon
  /// (JSON array of { id, type: "image"|"video", url, alt?, caption? })
  mediaCarouselJson   Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

/// Admin-editable catalog products per platform shop (source of truth for storefront catalog).
model ShopCatalogListing {
  id                  String   @id @default(cuid())
  shopSlug            String
  name                String
  summary             String
  description         String
  priceCents          Int
  /// physical | digital
  type                String
  categoryId          String
  imageUrl            String?
  /// cover | contain
  imageFit            String?
  badge               String?
  format              String?
  /// JSON array matching ProductOption[] in types/product.ts
  optionsJson         String?
  stripePaymentLink   String?
  /// DRAFT | PUBLISHED | ARCHIVED (see LISTING_STATUS)
  status              String   @default("DRAFT")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([shopSlug])
  @@index([shopSlug, status])
}

/// Weekly recurring availability for bookable services (offering-level).
model ServiceAvailabilityRule {
  id           String   @id @default(cuid())
  offeringId   String
  offering     Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  /// 0 = Sunday … 6 = Saturday
  dayOfWeek    Int
  /// Minutes from midnight in rule time zone (e.g. 540 = 09:00)
  startMinutes Int
  endMinutes   Int
  timeZone     String   @default("America/New_York")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([offeringId])
  @@index([offeringId, dayOfWeek])
}

/// Vendor-defined intake questions shown during service booking.
model ServiceIntakeQuestion {
  id         String   @id @default(cuid())
  offeringId String
  offering   Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  sortOrder  Int      @default(0)
  question   String
  required   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([offeringId])
}

/// PostgreSQL source of truth for service bookings; Google Calendar is sync target.
model Booking {
  id                String    @id @default(cuid())
  listingId         String
  listing           Listing   @relation(fields: [listingId], references: [id], onDelete: Restrict)
  offeringId        String
  offering          Offering  @relation(fields: [offeringId], references: [id], onDelete: Restrict)
  variantId         String?
  variant           OfferingVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)
  vendorProfileId   String
  vendorProfile     VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Restrict)
  memberUserId      String
  member            User      @relation("BookingMember", fields: [memberUserId], references: [id], onDelete: Restrict)
  memberEmail       String
  memberName        String?
  vendorEmail       String
  /// PENDING_PAYMENT | CONFIRMED | CANCELLED | COMPLETED — see BOOKING_STATUS
  status            String    @default("PENDING_PAYMENT")
  serviceKind       String
  fulfillmentMethod String    @default("VIRTUAL")
  scheduledStartAt  DateTime
  scheduledEndAt    DateTime
  timeZone          String    @default("America/New_York")
  priceCents        Int
  intakeNotes       String?
  vendorNotes       String?
  orderId           String?   @unique
  order             Order?    @relation(fields: [orderId], references: [id], onDelete: SetNull)
  stripeSessionId   String?   @unique
  calendarEventId   String?
  calendarProvider  String?
  meetLink          String?
  calendarHtmlLink  String?
  cancelledAt       DateTime?
  cancellationReason String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  intakeAnswers     BookingIntakeAnswer[]
  growthConsultationLeads GrowthConsultationLead[]
  vendorPulseReview VendorPulseReview?

  @@index([listingId])
  @@index([offeringId])
  @@index([memberUserId])
  @@index([vendorProfileId])
  @@index([scheduledStartAt])
  @@index([status])
}

model BookingIntakeAnswer {
  id           String  @id @default(cuid())
  bookingId    String
  booking      Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  questionText String
  answer       String

  @@index([bookingId])
}

/// Priced option within an Offering (e.g. Seed Session $50/30min, Garden Blueprint $100/60min).
model OfferingVariant {
  id              String   @id @default(cuid())
  offeringId      String
  offering        Offering @relation(fields: [offeringId], references: [id], onDelete: Cascade)
  sortOrder       Int      @default(0)
  title           String
  priceCents      Int
  /// Session length for SERVICE variants; optional for products/resources
  durationMinutes Int?
  /// Optional SKU for PRODUCT variants
  sku             String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  bookings        Booking[]
  orderItems      OrderItem[]

  @@index([offeringId])
  @@index([offeringId, sortOrder])
}

// ─── Growth Workspace (ADR-007) ─────────────────────────────────────────────
// See docs/20_GROWTH_WORKSPACE_SCHEMA.md

/// Vendor-scoped CRM contact. vendorProfileId null = platform (admin) contact.
model GrowthContact {
  id                       String    @id @default(cuid())
  vendorProfileId          String?
  vendorProfile            VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  rootSyncUserId           String?
  rootSyncUser             User?     @relation("GrowthContactMember", fields: [rootSyncUserId], references: [id], onDelete: SetNull)
  name                     String
  email                    String
  phone                    String?
  /// Member, Vendor, Visitor, etc.
  accountType              String?
  /// NEW_LEAD | SUBSCRIBER | COMMUNITY_MEMBER | CUSTOMER | RETURNING_CUSTOMER | VIP | PARTNER | SPONSOR | INACTIVE
  status                   String    @default("NEW_LEAD")
  leadSource               String?
  geographicRegion         String?
  growingZone              String?
  interestsJson            Json?
  funnelId                 String?
  funnel                   GrowthFunnel? @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  lastActivityAt           DateTime?
  communityActivitySummary String?
  purchaseSummary          String?
  consultationSummary      String?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  tags                     GrowthContactTag[]
  notes                    GrowthCrmNote[]
  tasks                    GrowthTask[]
  consultationLeads        GrowthConsultationLead[]
  marketingEvents          GrowthMarketingEvent[]

  @@index([vendorProfileId, email])
  @@index([vendorProfileId, status])
  @@index([rootSyncUserId])
  @@index([funnelId])
  @@map("growth_contacts")
}

model GrowthTag {
  id              String   @id @default(cuid())
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  name            String
  color           String?
  createdAt       DateTime @default(now())
  contacts        GrowthContactTag[]

  @@unique([vendorProfileId, name])
  @@index([vendorProfileId])
  @@map("growth_tags")
}

model GrowthContactTag {
  contactId String
  contact   GrowthContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  tagId     String
  tag       GrowthTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([contactId, tagId])
  @@map("growth_contact_tags")
}

model GrowthCrmNote {
  id           String        @id @default(cuid())
  contactId    String
  contact      GrowthContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  authorUserId String
  author       User          @relation("GrowthCrmNoteAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  body         String
  createdAt    DateTime      @default(now())

  @@index([contactId])
  @@map("growth_crm_notes")
}

model GrowthTask {
  id              String         @id @default(cuid())
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  contactId       String?
  contact         GrowthContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  title           String
  dueAt           DateTime?
  completedAt     DateTime?
  /// LOW | NORMAL | HIGH
  priority        String         @default("NORMAL")
  createdAt       DateTime       @default(now())

  @@index([vendorProfileId, completedAt])
  @@index([contactId])
  @@map("growth_tasks")
}

model GrowthFunnel {
  id              String         @id @default(cuid())
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  objective       String?
  entrySource     String?
  landingPageId   String?
  landingPage     GrowthLandingPage? @relation("FunnelLandingPage", fields: [landingPageId], references: [id], onDelete: SetNull)
  leadMagnet      String?
  ctaLabel        String?
  isActive        Boolean        @default(true)
  metricsJson     Json?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  steps           GrowthFunnelStep[]
  contacts        GrowthContact[]
  qrCampaigns     GrowthQrCampaign[]
  emailSequences  GrowthEmailSequence[]
  consultationLeads GrowthConsultationLead[]
  marketingEvents GrowthMarketingEvent[]
  landingPages    GrowthLandingPage[] @relation("LandingPageFunnel")

  @@index([vendorProfileId, isActive])
  @@map("growth_funnels")
}

model GrowthFunnelStep {
  id            String       @id @default(cuid())
  funnelId      String
  funnel        GrowthFunnel @relation(fields: [funnelId], references: [id], onDelete: Cascade)
  sortOrder     Int
  /// LANDING_PAGE | LEAD_MAGNET | EMAIL_SEQUENCE | NEWSLETTER | CTA | CONSULTATION | MARKETPLACE | REFERRAL
  stepType      String
  label         String
  referenceId   String?
  referenceType String?

  @@unique([funnelId, sortOrder])
  @@index([funnelId])
  @@map("growth_funnel_steps")
}

model GrowthLandingPage {
  id              String         @id @default(cuid())
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  funnelId        String?
  funnel          GrowthFunnel?  @relation("LandingPageFunnel", fields: [funnelId], references: [id], onDelete: SetNull)
  slug            String
  title           String
  headline        String?
  contentJson     Json?
  leadMagnetUrl   String?
  isPublished     Boolean        @default(false)
  viewCount       Int            @default(0)
  conversionCount Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  funnelsAsEntry  GrowthFunnel[] @relation("FunnelLandingPage")
  qrCampaigns     GrowthQrCampaign[]
  marketingEvents GrowthMarketingEvent[]

  @@unique([vendorProfileId, slug])
  @@index([vendorProfileId, isPublished])
  @@map("growth_landing_pages")
}

model GrowthQrCampaign {
  id              String         @id @default(cuid())
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  name            String
  /// INVESTFEST | FARMERS_MARKET | WORKSHOP | BOOK | SEED_KIT | PODCAST | etc.
  campaignType    String
  destinationUrl  String
  landingPageId   String?
  landingPage     GrowthLandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  funnelId        String?
  funnel          GrowthFunnel?  @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  scanCount       Int            @default(0)
  conversionCount Int            @default(0)
  notes           String?
  isActive        Boolean        @default(true)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  marketingEvents GrowthMarketingEvent[]

  @@index([vendorProfileId, isActive])
  @@map("growth_qr_campaigns")
}

model GrowthEmailCampaign {
  id                String         @id @default(cuid())
  vendorProfileId   String?
  vendorProfile     VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  name              String
  subject           String?
  bodyHtml          String?
  /// DRAFT | SCHEDULED | SENDING | SENT | CANCELLED
  status            String         @default("DRAFT")
  scheduledAt       DateTime?
  sentAt            DateTime?
  segmentId         String?
  segment           GrowthSegment? @relation(fields: [segmentId], references: [id], onDelete: SetNull)
  openCount         Int            @default(0)
  clickCount        Int            @default(0)
  unsubscribeCount  Int            @default(0)
  providerMessageId String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  marketingEvents   GrowthMarketingEvent[]

  @@index([vendorProfileId, status])
  @@map("growth_email_campaigns")
}

model GrowthEmailSequence {
  id              String         @id @default(cuid())
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  name            String
  /// WELCOME | EDUCATIONAL | SEASONAL | PRODUCT_LAUNCH | COMMUNITY | EVENT
  sequenceType    String
  stepsJson       Json
  isActive        Boolean        @default(false)
  funnelId        String?
  funnel          GrowthFunnel?  @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  @@index([vendorProfileId, isActive])
  @@map("growth_email_sequences")
}

model GrowthSegment {
  id              String         @id @default(cuid())
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  name            String
  description     String?
  rulesJson       Json?
  isDynamic       Boolean        @default(true)
  memberCount     Int            @default(0)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  emailCampaigns  GrowthEmailCampaign[]

  @@index([vendorProfileId])
  @@map("growth_segments")
}

model GrowthConsultationLead {
  id              String        @id @default(cuid())
  vendorProfileId String
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  contactId       String
  contact         GrowthContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  bookingId       String?
  booking         Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  /// LEAD | REQUESTED | SCHEDULED | COMPLETED | PROPOSAL_SENT | ACCEPTED | DECLINED | PROJECT_COMPLETE | REVIEW_RECEIVED
  stage           String        @default("LEAD")
  source          String?
  funnelId        String?
  funnel          GrowthFunnel? @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  notes           String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([vendorProfileId, stage])
  @@index([contactId])
  @@index([bookingId])
  @@map("growth_consultation_leads")
}

model GrowthMarketingEvent {
  id              String         @id @default(cuid())
  vendorProfileId String?
  vendorProfile   VendorProfile? @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  /// PAGE_VIEW | QR_SCAN | EMAIL_OPEN | EMAIL_CLICK | CONVERSION | SIGNUP
  eventType       String
  contactId       String?
  contact         GrowthContact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  rootSyncUserId  String?
  rootSyncUser    User?          @relation("GrowthMarketingEventUser", fields: [rootSyncUserId], references: [id], onDelete: SetNull)
  funnelId        String?
  funnel          GrowthFunnel?  @relation(fields: [funnelId], references: [id], onDelete: SetNull)
  landingPageId   String?
  landingPage     GrowthLandingPage? @relation(fields: [landingPageId], references: [id], onDelete: SetNull)
  qrCampaignId    String?
  qrCampaign      GrowthQrCampaign? @relation(fields: [qrCampaignId], references: [id], onDelete: SetNull)
  campaignId      String?
  campaign        GrowthEmailCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  metadataJson    Json?
  occurredAt      DateTime       @default(now())

  @@index([vendorProfileId, eventType, occurredAt])
  @@index([landingPageId])
  @@index([qrCampaignId])
  @@map("growth_marketing_events")
}

// --- Pulse ecosystem (ADR-008) ---

model PulseCategory {
  id        String   @id @default(cuid())
  key       String   @unique
  label     String
  sortOrder Int      @default(0)
  enabled   Boolean  @default(true)
  weights   PulseScoreWeight[]
  events    PulseEvent[]

  @@map("pulse_categories")
}

model PulseEvent {
  id                String         @id @default(cuid())
  userId            String
  user              User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventType         String
  categoryId        String?
  category          PulseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pulseValue        Int
  relatedEntityType String?
  relatedEntityId   String?
  metadataJson      Json?
  createdAt         DateTime       @default(now())

  @@index([userId, createdAt])
  @@index([eventType, createdAt])
  @@index([relatedEntityType, relatedEntityId])
  @@index([categoryId])
  @@map("pulse_events")
}

model PulseReaction {
  id          String        @id @default(cuid())
  postId      String
  post        CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  giverUserId String
  giver       User          @relation("PulseReactionGiver", fields: [giverUserId], references: [id], onDelete: Cascade)
  createdAt   DateTime      @default(now())

  @@unique([postId, giverUserId])
  @@index([postId])
  @@map("pulse_reactions")
}

model PulseScore {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  totalScore    Int      @default(0)
  /// EMERGING | GROWING | ROOTED | FLOURISHING | CONNECTED | CANOPY
  status        String   @default("EMERGING")
  /// INCREASING | STABLE | QUIET | RETURNING
  activityTrend String?
  pulseThisWeek Int?
  /// @deprecated use activityTrend — kept for migration compatibility
  trend7d       Int?
  lastEventAt   DateTime?
  updatedAt     DateTime @updatedAt

  @@map("pulse_scores")
}

model PulseScoreWeight {
  id          String         @id @default(cuid())
  eventType   String         @unique
  categoryId  String?
  category    PulseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  pulseValue  Int
  enabled     Boolean        @default(true)
  description String?
  updatedAt   DateTime       @updatedAt

  @@index([categoryId])
  @@map("pulse_score_weights")
}

model PulseThreshold {
  id        String @id @default(cuid())
  status    String @unique
  minScore  Int
  label     String
  emoji     String?
  sortOrder Int    @default(0)

  @@map("pulse_thresholds")
}

model PlatformPulseWeight {
  id          String   @id @default(cuid())
  metricKey   String   @unique
  weight      Float    @default(1)
  enabled     Boolean  @default(true)
  description String?
  updatedAt   DateTime @updatedAt

  @@map("platform_pulse_weights")
}

model PlatformPulseThreshold {
  id        String @id @default(cuid())
  status    String @unique
  minValue  Int
  label     String
  emoji     String?
  sortOrder Int    @default(0)

  @@map("platform_pulse_thresholds")
}

model PlatformPulseSnapshot {
  id          String   @id @default(cuid())
  pulseValue  Int      @default(0)
  status      String
  metricsJson Json?
  computedAt  DateTime @default(now())

  @@index([computedAt])
  @@map("platform_pulse_snapshots")
}

model PlatformPulseDaily {
  id                String   @id @default(cuid())
  date              DateTime @unique @db.Date
  totalPulseValue   Int      @default(0)
  eventCount        Int      @default(0)
  activeMemberCount Int      @default(0)
  computedAt        DateTime @default(now())

  @@map("platform_pulse_daily")
}

model PublicDashboardWidget {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  widgetType  String
  enabled     Boolean  @default(true)
  sortOrder   Int      @default(0)
  configJson  Json?
  updatedAt   DateTime @updatedAt

  @@map("public_dashboard_widgets")
}

model PublicDashboardAnnouncement {
  id        String    @id @default(cuid())
  title     String
  body      String?
  href      String?
  startsAt  DateTime?
  endsAt    DateTime?
  enabled   Boolean   @default(true)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())

  @@map("public_dashboard_announcements")
}

/// Member Pulse ratings for vendors — replaces star reviews (ADR-008 Phase 7).
model VendorPulseReview {
  id              String        @id @default(cuid())
  vendorProfileId String
  vendorProfile   VendorProfile @relation(fields: [vendorProfileId], references: [id], onDelete: Cascade)
  reviewerUserId  String
  reviewer        User          @relation("VendorPulseReviewAuthor", fields: [reviewerUserId], references: [id], onDelete: Cascade)
  listingId       String?
  listing         Listing?      @relation(fields: [listingId], references: [id], onDelete: SetNull)
  orderId         String?       @unique
  order           Order?        @relation(fields: [orderId], references: [id], onDelete: SetNull)
  bookingId       String?       @unique
  booking         Booking?      @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  /// 1 – 5 Pulse rating
  pulseRating     Int
  title           String?
  body            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([vendorProfileId, createdAt])
  @@index([reviewerUserId])
  @@map("vendor_pulse_reviews")
}
